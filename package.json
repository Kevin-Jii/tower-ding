{
  "name": "tower-ding",
  "version": "1.0.0",
  "private": true,
  "description": "基于taro的多门店数据管理中心，配套tower-go",
  "templateInfo": {
    "name": "vue3-pinia",
    "typescript": true,
    "css": "Less",
    "framework": "Vue3"
  },
  "scripts": {
    "postinstall": "node scripts/patch-taro-vite-runner.js",
    "build:weapp": "taro build --type weapp",
    "dev:weapp": "npm run build:weapp -- --watch",
    "build:h5": "taro build --type h5",
    "dev:h5": "npm run build:h5 -- --watch",
    "build:android": "taro build --type h5 --mode android && cap sync android",
    "dev:android": "npm run dev:h5 -- --mode android",
    "cap:add:android": "cap add android",
    "cap:sync": "cap sync",
    "cap:open:android": "cap open android"
  },
  "browserslist": [
    "defaults and fully supports es6-module",
    "maintained node versions"
  ],
  "engines": {
    "node": ">=20"
  },
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@babel/runtime": "^7.7.7",
    "@tarojs/components": "4.1.11",
    "@tarojs/helper": "4.1.11",
    "@tarojs/plugin-framework-vue3": "4.1.11",
    "@tarojs/plugin-platform-h5": "4.1.11",
    "@tarojs/plugin-platform-weapp": "4.1.11",
    "@tarojs/runtime": "4.1.11",
    "@tarojs/shared": "4.1.11",
    "@tarojs/taro": "4.1.11",
    "@capacitor/core": "^7.6.5",
    "echarts": "5.6.0",
    "pinia": "^2.0.10",
    "resolve": "^1.22.12",
    "vue": "^3.5.13"
  },
  "devDependencies": {
    "@babel/core": "^7.8.0",
    "@babel/plugin-proposal-class-properties": "7.14.5",
    "@capacitor/android": "^7.6.5",
    "@capacitor/cli": "^7.6.5",
    "@tarojs/cli": "4.1.11",
    "@tarojs/vite-runner": "4.1.11",
    "@types/node": "^18.19.99",
    "@typescript-eslint/eslint-plugin": "^6.2.0",
    "@typescript-eslint/parser": "^6.2.0",
    "@vitejs/plugin-vue": "^4.6.2",
    "@vitejs/plugin-vue-jsx": "^3.1.0",
    "@vue/babel-plugin-jsx": "^1.0.6",
    "@vue/compiler-sfc": "^3.5.13",
    "babel-preset-taro": "4.1.11",
    "eslint": "^8.12.0",
    "eslint-config-taro": "4.1.11",
    "eslint-plugin-vue": "^9.17.0",
    "less": "^4.2.2",
    "postcss": "^8.4.18",
    "stylelint": "^14.4.0",
    "terser": "^5.39.2",
    "typescript": "^5.1.0",
    "vite": "^4.5.14"
  }
}
